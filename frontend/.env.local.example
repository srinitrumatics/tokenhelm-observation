# Path to the append-only usage audit log produced by the ADK cost tracker.
# Resolved relative to the frontend/ working directory. The app reads this file
# READ-ONLY and never modifies it. This is the v1 JsonlEventSource backing the
# observability platform (and the legacy cost dashboard).
USAGE_LOG_PATH=../usage_log.jsonl

# Storage backend selector. The analytics layer depends only on the EventSource
# interface, so the sink is swappable here WITHOUT changing any aggregator.
#   jsonl    (default) → ../usage_log.jsonl (USAGE_LOG_PATH above)
#   duckdb            → DUCKDB_PATH (embedded columnar engine, large datasets)
#   postgres          → PG_DSN (connector ecosystem, v1.4)
EVENT_SOURCE=jsonl

# DuckDB sink (EVENT_SOURCE=duckdb). Ingest first: node scripts/ingest-duckdb.mjs
# DUCKDB_PATH=../usage.duckdb

# Postgres sink (EVENT_SOURCE=postgres, v1.4). Ingest first: node scripts/ingest-postgres.mjs
# The app connects READ-ONLY; only the ingest script writes. No insecure default — must be set.
# PG_DSN=postgres://user:password@localhost:5432/observability
