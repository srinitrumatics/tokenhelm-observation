{
  "name": "@tokenhelm/observation-sdk",
  "version": "0.1.0",
  "description": "Producer SDK for the Observation Protocol v1 (TypeScript/Node) — emit canonical ObservationEvents for the AI Observation Platform.",
  "license": "MIT",
  "author": "Trumatics",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "keywords": [
    "observability",
    "llm",
    "tokenhelm",
    "observationevent",
    "ai"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "gen:fixture": "npm run build && node dist/examples/generateFixture.js"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
