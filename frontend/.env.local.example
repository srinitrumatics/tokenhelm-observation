# Path to the append-only usage audit log produced by the ADK cost tracker.
# Resolved relative to the frontend/ working directory. The app reads this file
# READ-ONLY and never modifies it. This is the v1 JsonlEventSource backing the
# observability platform (and the legacy cost dashboard).
USAGE_LOG_PATH=../usage_log.jsonl

# Storage backend selector (forward-looking). The analytics layer depends only on
# the EventSource interface, so future sinks (DuckDB / PostgreSQL / Redis Streams /
# OpenTelemetry) can be selected here WITHOUT changing any aggregator. v1 supports
# only "jsonl"; later phases add others (see plan.md task T059).
EVENT_SOURCE=jsonl
